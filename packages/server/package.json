    "@clerk/backend": "^3.11.4",
    "@hono/zod-validator": "^0.8.0",
    "@sentry/bun": "^10.64.0",
    "@sentry/hono": "^10.64.0",
    "@sora/database": "workspace:*",
    "@sora/shared": "workspace:*",
    "ai": "^7.0.19",
    "dotenv": "^17.4.2",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
